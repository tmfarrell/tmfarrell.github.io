{%- if site.data.portfolio.size > 0 -%}
,
{%- endif -%}
{%- for item in site.data.portfolio -%}
  {%- assign item_year = item.date | date: "%Y" | plus: 0 -%}
  {%- assign content = item.description -%}
  {%- if item_year < 2019 -%}
    {%- assign content = "" -%}
  {%- endif -%}
  {
    "title": {{ item.title | jsonify }},
    "url": {{ item.link | jsonify }},
    "content": {{ content | jsonify }},
    "category": "portfolio",
    "date": {{ item.date | jsonify }}
    {%- if item.tags -%}
    ,"tags": {{ item.tags | jsonify }}
    {%- endif -%}
    {%- if item.org -%}
    ,"org": {{ item.org | jsonify }}
    {%- endif -%}
  }{% unless forloop.last %},{% endunless %}
{%- endfor -%}
{%- assign posts_with_category = "" | split: "" -%}
{%- for post in site.posts -%}
  {%- if post.categories and post.categories.size > 0 -%}
    {%- assign posts_with_category = posts_with_category | push: post -%}
  {%- endif -%}
{%- endfor -%}
{%- assign sorted_posts = posts_with_category | sort: "date" | reverse -%}
{%- if posts_with_category.size > 0 -%}
,
{%- endif -%}
{%- for post in sorted_posts -%}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | jsonify }},
    "content": {{ post.content | strip_html | strip_newlines | jsonify }},
    "category": {{ post.categories | first | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }}
    {%- if post.tags -%}
    ,"tags": {{ post.tags | jsonify }}
    {%- endif -%}
  }{% unless forloop.last %},{% endunless %}
{%- endfor -%}
]
